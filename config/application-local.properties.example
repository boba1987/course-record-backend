# Copy to config/application-local.properties (gitignored) and fill in real values.

server.port=8080

# MySQL — createDatabaseIfNotExist creates the schema if missing
spring.datasource.url=jdbc:mysql://localhost:3306/course_record?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.username=local-user
spring.datasource.password=CHANGE_ME

# JWT signing (HS256) — use a long random secret in production
jwt.secret=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_256_BITS
jwt.expiration-ms=3600000

# Bootstrap admin (seeded when DB is empty)
app.admin.username=admin
app.admin.password=CHANGE_ME

# Browser front-end origins (comma-separated). Match Next.js dev server.
# app.cors.allowed-origins=http://localhost:3000
