<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="setup-001" author="course-record">
        <createTable tableName="app_user">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="setup-002" author="course-record">
        <createTable tableName="professor">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="setup-003" author="course-record">
        <createTable tableName="course">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="espb" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="professor_id" type="BIGINT"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="course"
                                 baseColumnNames="professor_id"
                                 constraintName="fk_course_professor"
                                 referencedTableName="professor"
                                 referencedColumnNames="id"
                                 onDelete="SET NULL"
                                 onUpdate="CASCADE"/>
    </changeSet>

    <changeSet id="setup-004" author="course-record">
        <createTable tableName="course_semester">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="academic_year" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="semester" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="course_semester"
                                 baseColumnNames="course_id"
                                 constraintName="fk_course_semester_course"
                                 referencedTableName="course"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"/>
        <addUniqueConstraint tableName="course_semester"
                             columnNames="course_id, academic_year, semester"
                             constraintName="uk_course_semester_course_year_semester"/>
    </changeSet>

    <changeSet id="setup-005" author="course-record">
        <createTable tableName="student">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="index_number" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="setup-006" author="course-record">
        <createTable tableName="enrollment">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="enrollment"
                                 baseColumnNames="student_id"
                                 constraintName="fk_enrollment_student"
                                 referencedTableName="student"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="enrollment"
                                 baseColumnNames="course_id"
                                 constraintName="fk_enrollment_course"
                                 referencedTableName="course"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"/>
        <addUniqueConstraint tableName="enrollment"
                             columnNames="student_id, course_id"
                             constraintName="uk_enrollment_student_course"/>
    </changeSet>

    <changeSet id="setup-007" author="course-record">
        <createTable tableName="exam">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="exam_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="grade" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="exam"
                                 baseColumnNames="student_id"
                                 constraintName="fk_exam_student"
                                 referencedTableName="student"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="exam"
                                 baseColumnNames="course_id"
                                 constraintName="fk_exam_course"
                                 referencedTableName="course"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"/>
        <addUniqueConstraint tableName="exam"
                             columnNames="student_id, course_id"
                             constraintName="uk_exam_student_course"/>
    </changeSet>

    <changeSet id="setup-008" author="course-record">
        <createTable tableName="author">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="setup-009" author="course-record">
        <createTable tableName="book">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="publication_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="author_id" type="BIGINT"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="book"
                                 baseColumnNames="author_id"
                                 constraintName="fk_book_author"
                                 referencedTableName="author"
                                 referencedColumnNames="id"
                                 onDelete="SET NULL"
                                 onUpdate="CASCADE"/>
    </changeSet>

    <changeSet id="setup-010" author="course-record">
        <createTable tableName="course_book">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="book_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="course_book"
                                 baseColumnNames="course_id"
                                 constraintName="fk_course_book_course"
                                 referencedTableName="course"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"/>
        <addForeignKeyConstraint baseTableName="course_book"
                                 baseColumnNames="book_id"
                                 constraintName="fk_course_book_book"
                                 referencedTableName="book"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"/>
        <addUniqueConstraint tableName="course_book"
                             columnNames="course_id, book_id"
                             constraintName="uk_course_book_course_book"/>
    </changeSet>

</databaseChangeLog>
